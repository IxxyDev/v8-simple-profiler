{
  "name": "v8-deopt",
  "version": "1.0.0",
  "description": "V8 deoptimization profiler with comprehensive analysis and reporting",
  "main": "run.js",
  "bin": {
    "v8-profiler": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node run.js",
    "analyze": "node --allow-natives-syntax run.js",
    "profile": "node --trace-opt --trace-deopt run.js",
    "profile-deep": "node --trace-opt --trace-deopt --trace-deopt-verbose --allow-natives-syntax run.js",
    "profile-prof": "node --prof --trace-opt --trace-deopt run.js",
    "cli": "node src/cli/index.js",
    "cli:help": "node src/cli/index.js --help",
    "benchmark": "node src/cli/index.js --config config/profiler.config.js",
    "benchmark:json": "node src/cli/index.js --format json --output ./reports/",
    "benchmark:csv": "node src/cli/index.js --format csv --output ./reports/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:config": "vitest run tests/unit/config.test.js"
  },
  "keywords": ["v8", "profiler", "deoptimization", "performance", "benchmark", "optimization"],
  "author": "IxxyDev",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "chalk": "^5.0.0"
  },
  "devDependencies": {
    "vitest": "^1.0.0"
  }
}
